VERSION="1.2.0"

##############################################################################
# Display Toolkit Header
##############################################################################

header() {
    echo
    echo "=================================================="
    echo "           Nokia Beacon 3.2"
    echo "        Diagnostic Toolkit"
    printf "             NBDT v%s\n" "$VERSION"
    echo "=================================================="

    [ -n "$1" ] && printf "  %s\n" "$1"

    echo "=================================================="
}

##############################################################################
# Horizontal Separator
##############################################################################

line() {
    echo "--------------------------------------------------"
}

##############################################################################
# Status Messages
##############################################################################

ok() {
    printf "[ OK ] %s\n" "$1"
}

warn() {
    printf "[WARN] %s\n" "$1"
}

fail() {
    printf "[FAIL] %s\n" "$1"
}

##############################################################################
# Check if Command Exists
##############################################################################

exists() {
    command -v "$1" >/dev/null 2>&1
}
